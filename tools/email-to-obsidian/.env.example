# Copy to .env (or export these) before running. Do NOT commit your real .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional. Defaults to claude-opus-4-8. For cheaper high-volume runs:
#   MOGS_MODEL=claude-haiku-4-5
# MOGS_MODEL=claude-opus-4-8

# --- Gmail ---
# OAuth desktop client downloaded from Google Cloud Console (see README).
MOGS_CREDENTIALS_FILE=credentials.json
MOGS_TOKEN_FILE=token.json
MOGS_LABEL=mogs
MOGS_DONE_LABEL=mogs-filed

# --- Obsidian vault (a git repo) ---
MOGS_VAULT=/absolute/path/to/your/ObsidianVault
MOGS_FLOW_DIR=Flow
MOGS_GIT_COMMIT=1
MOGS_GIT_PUSH=0
